# Prebetter Frontend - Nuxt auto-maps NUXT_* to runtimeConfig (12-factor)
# Copy to .env and fill in all values

# API backend URL
NUXT_API_BASE=http://localhost:8000

# Session encryption (generate with: openssl rand -hex 32)
NUXT_SESSION_PASSWORD=

# Cookie security (true for production behind HTTPS)
NUXT_SESSION_COOKIE_SECURE=false
