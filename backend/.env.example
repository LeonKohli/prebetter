MYSQL_USER=username
MYSQL_PASSWORD=password
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_PRELUDE_DB=prelude
MYSQL_PREBETTER_DB=prebetter
SECRET_KEY=your-super-secret-key-that-should-be-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15   # Short-lived access tokens (auto-refreshed by frontend)
REFRESH_TOKEN_EXPIRE_DAYS=7      # Long-lived refresh tokens (must match frontend session maxAge)
BCRYPT_ROUNDS=14
# CORS origins (JSON array of origins)
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
# Logging configuration
# Options: development, production
ENVIRONMENT=development
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO 
